<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 헤더 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 입금 알림 연동"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="은행 입금 문자를 자동으로 OBS 시스템에 전송합니다"
            android:textSize="13sp"
            android:textColor="#8888aa"
            android:layout_marginBottom="20dp"/>

        <!-- 상태 표시 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🟢 SMS 자동 전송 활성화됨"
            android:textSize="15sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="16dp"/>

        <!-- 자동 전송 토글 -->
        <Switch
            android:id="@+id/swEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="자동 전송 활성화"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <!-- 서버 설정 섹션 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="서버 설정"
            android:textColor="#aaaacc"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API 서버 주소"
            android:textColorHint="#555577"
            android:textColor="#ffffff"
            android:background="#1e1e2e"
            android:padding="12dp"
            android:inputType="textUri"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/etProjectId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="프로젝트 ID"
            android:textColorHint="#555577"
            android:textColor="#ffffff"
            android:background="#1e1e2e"
            android:padding="12dp"
            android:inputType="number"
            android:layout_marginBottom="16dp"/>

        <!-- 설정 저장 버튼 -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="설정 저장"
            android:backgroundTint="#6c35de"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"/>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333355"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"/>

        <!-- 테스트 전송 버튼 -->
        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧪 서버 연결 테스트 전송"
            android:backgroundTint="#1e8e3e"
            android:textColor="#ffffff"
            android:textSize="15sp"
            android:layout_marginBottom="8dp"/>

        <!-- 배터리 최적화 제외 버튼 -->
        <Button
            android:id="@+id/btnBatteryOpt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔋 배터리 최적화 제외 설정"
            android:backgroundTint="#e65c00"
            android:textColor="#ffffff"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- 안내 텍스트 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ SMS가 수신 안 되면:\n1. 배터리 최적화 제외 버튼 누르기\n2. 설정 > 앱 > 입금알림연동 > SMS 권한 허용\n3. 설정 > 배터리 > 백그라운드 제한 없음 설정"
            android:textColor="#ffcc00"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- 최근 수신 기록 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="최근 수신 기록"
            android:textColor="#aaaacc"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="아직 수신된 입금 문자가 없습니다."
            android:textColor="#ccccdd"
            android:textSize="13sp"
            android:background="#1e1e2e"
            android:padding="12dp"/>

    </LinearLayout>
</ScrollView>
